{
  "name": "neverthrow-parse",
  "version": "0.0.1",
  "description": "Type-safe parsers for unknown data using neverthrow Result types",
  "license": "MIT",
  "author": "Stanislav Titenko",
  "keywords": [
    "neverthrow",
    "parser",
    "validation",
    "result",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resetko/neverthrow-parse.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm test && pnpm lint && pnpm build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "neverthrow": "^8.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "neverthrow": "^8.2.0"
  }
}
